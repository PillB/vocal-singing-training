{
  "name": "vocal-and-singing-training",
  "version": "1.0.0",
  "description": "Self-paced Vocal & Singing Training practice site",
  "scripts": {
    "test": "node qa/check-catalog.mjs && playwright test",
    "test:e2e": "playwright test",
    "test:catalog": "node qa/check-catalog.mjs",
    "test:geometry": "node qa/capture-geometry.mjs && python3 qa/analyze_geometry.py",
    "catalog:rebuild": "node qa/rebuild-catalog-snapshot.mjs",
    "accounts:generate": "node qa/generate-test-accounts.mjs",
    "serve": "python3 -m http.server 8765",
    "start": "python3 -m http.server 8765"
  },
  "keywords": ["vocal", "singing", "training", "education"],
  "author": "PillB",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1"
  }
}
